# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/fundloop?schema=public"

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── M-Pesa (Daraja API) ──────────────────────────────────────────────────────
# Leave blank — M-Pesa is stubbed in dev. Fill in for production.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=

# ─── SMS (Africa's Talking) ───────────────────────────────────────────────────
# Leave blank — SMS is stubbed in dev (logs to console instead).
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=FundLoop
